{
  "name": "epub-cover-changer",
  "version": "0.0.1",
  "author": "Ionic Framework",
  "homepage": "https://ionicframework.com/",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "prebuild": "node ../../scripts/ensure-stencil-entry.cjs && node ../../scripts/patch-capacitor-status-bar.cjs && node ../../scripts/patch-capacitor-admob.cjs && node ../../scripts/patch-capacitor-filesystem.cjs",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "assets:android": "node ../../scripts/run-capacitor-assets.cjs generate --android",
    "debugApk": "node ../../scripts/run-mobile-android-flow.cjs assembleDebug --copy-apk .\\app\\build\\outputs\\apk\\debug\\app-debug.apk --copy-to \"G:\\Mi unidad\"",
    "releaseApk": "node ../../scripts/run-mobile-android-flow.cjs assembleRelease --copy-apk .\\app\\build\\outputs\\apk\\release\\app-release.apk --copy-to \"G:\\Mi unidad\"",
    "bundleRelease": "node ../../scripts/run-mobile-android-flow.cjs bundleRelease"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^22.0.7",
    "@angular/compiler": "^22.0.7",
