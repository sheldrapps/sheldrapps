/* To learn more about this file see: https://angular.io/config/tsconfig. */
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/app",
    "types": [],
    "paths": {
      "@sheldrapps/ad-fallback-kit": ["../../packages/ad-fallback-kit/src/public-api.ts"],
      "@sheldrapps/ads-kit": ["../../packages/ads-kit/src/public-api.ts"],
      "@sheldrapps/i18n-kit": ["../../packages/i18n-kit/src/public-api.ts"],
      "@sheldrapps/settings-kit": ["../../packages/settings-kit/src/public-api.ts"],
      "@sheldrapps/rating-kit": ["../../packages/rating-kit/src/public-api.ts"],
      "@sheldrapps/recommended-apps": ["../../packages/recommended-apps/src/public-api.ts"],
      "@sheldrapps/covers-list-kit": ["../../packages/covers-list-kit/src/public-api.ts"],
      "@sheldrapps/file-kit": ["../../packages/file-kit/src/public-api.ts"],
      "@sheldrapps/export-quality-kit": [
        "../../packages/export-quality-kit/src/public-api.ts"
      ],
      "@sheldrapps/best-candidate-kit": ["../../packages/best-candidate-kit/src/public-api.ts"],
      "@sheldrapps/image-workflow": ["../../packages/image-workflow/src/public-api.ts"],
      "@sheldrapps/image-workflow/capacitor": ["../../packages/image-workflow/src/lib/adapters/capacitor/public-api.ts"],
      "@sheldrapps/image-workflow/editor": ["../../packages/image-workflow/src/editor/public-api.ts"],
      "@sheldrapps/privacy-policy-kit": ["../../packages/privacy-policy-kit/src/public-api.ts"],
      "@sheldrapps/ui-theme": ["../../packages/ui-theme/src/index.ts"],
      "@sheldrapps/ui-theme/styles/*": ["../../packages/ui-theme/styles/*"]
    }
  },
  "files": [
    "src/main.ts",
    "src/main.native.ts",
    "src/polyfills.ts"
  ],
  "include": [
    "src/**/*.d.ts",
    "src/**/*.ts",
    "../../packages/image-workflow/src/editor/**/*.ts",
    "../../packages/image-workflow/src/lib/types/**/*.ts",
    "../../packages/image-workflow/src/lib/core/**/*.ts",
    "../../packages/image-workflow/src/lib/ui/**/*.ts",
    "../../packages/image-workflow/src/public-api.ts",
    "../../packages/ad-fallback-kit/src/**/*.ts",
    "../../packages/settings-kit/src/**/*.ts",
    "../../packages/recommended-apps/src/**/*.ts",
    "../../packages/covers-list-kit/src/**/*.ts",
    "../../packages/file-kit/src/**/*.ts",
    "../../packages/export-quality-kit/src/**/*.ts",
    "../../packages/best-candidate-kit/src/**/*.ts",
    "../../packages/privacy-policy-kit/src/**/*.ts",
    "../../packages/ui-theme/src/**/*.ts"
  ],
  "exclude": [
    "src/**/*.spec.ts",
    "../../packages/**/*.spec.ts"
  ]
}
