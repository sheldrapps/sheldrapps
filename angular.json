{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "sheldrapps-web": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "apps/sheldrapps-web",
      "sourceRoot": "apps/sheldrapps-web/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "apps/sheldrapps-web/src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "apps/sheldrapps-web/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "apps/sheldrapps-web/public"
              },
              {
                "glob": "icon.png",
                "input": "apps/cover-creator-for-kindle/resources",
                "output": "assets/apps/ccfk"
              },
              {
                "glob": "icon.png",
                "input": "apps/epub-cover-changer/resources",
                "output": "assets/apps/ecc"
              },
              {
                "glob": "icon.png",
                "input": "apps/pdf-cover-maker/resources",
                "output": "assets/apps/pcm"
              },
              {
                "glob": "icon.png",
                "input": "apps/epub-fixer/resources",
                "output": "assets/apps/epub-fixer"
              }
            ],
            "styles": [
              "apps/sheldrapps-web/src/styles.scss"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "sheldrapps-web:build:production"
            },
            "development": {
              "buildTarget": "sheldrapps-web:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}
