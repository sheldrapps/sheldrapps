{
  "name": "sheldrapps",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "i": "pnpm install",
    "postinstall": "node scripts/ensure-stencil-entry.cjs && node scripts/patch-capacitor-status-bar.cjs && node scripts/patch-capacitor-admob.cjs",
    "dev:cover": "pnpm --filter cover-creator-for-kindle start",
    "build:cover": "pnpm --filter cover-creator-for-kindle build",
    "android:cover": "pnpm --filter cover-creator-for-kindle debugApk",
    "dev:compress": "pnpm --filter compress-pdf start",
    "build:compress": "pnpm --filter compress-pdf build",
    "lint:compress": "pnpm --filter compress-pdf lint",
    "dev:presupuesto": "pnpm --filter presupuesto-ninos start",
    "build:presupuesto": "pnpm --filter presupuesto-ninos build",
    "lint:presupuesto": "pnpm --filter presupuesto-ninos lint",
    "android:install": "powershell -ExecutionPolicy Bypass -File scripts/install-android-debug.ps1",
    "android:install:ecc": "powershell -ExecutionPolicy Bypass -File scripts/install-android-debug.ps1 -AppName epub-cover-changer",
    "android:install:pcm": "powershell -ExecutionPolicy Bypass -File scripts/install-android-debug.ps1 -AppName pdf-cover-maker",
    "android:install:ccfk": "powershell -ExecutionPolicy Bypass -File scripts/install-android-debug.ps1 -AppName cover-creator-for-kindle",
    "android:clean-install:ecc": "powershell -ExecutionPolicy Bypass -File scripts/install-android-debug.ps1 -AppName epub-cover-changer -UninstallFirst",
    "android:clean-install:pcm": "powershell -ExecutionPolicy Bypass -File scripts/install-android-debug.ps1 -AppName pdf-cover-maker -UninstallFirst",
    "android:clean-install:ccfk": "powershell -ExecutionPolicy Bypass -File scripts/install-android-debug.ps1 -AppName cover-creator-for-kindle -UninstallFirst",
    "phone:ecc": "pnpm android:install:ecc",
    "phone:ecc:me": "pnpm android:install:ecc -- -DeviceId R5CY21M3ZRY",
    "phone:pcm": "pnpm android:install:pcm",
    "phone:pcm:me": "pnpm android:install:pcm -- -DeviceId R5CY21M3ZRY",
    "phone:ccfk": "pnpm android:install:ccfk",
    "phone:ccfk:me": "pnpm android:install:ccfk -- -DeviceId R5CY21M3ZRY",
    "clean-phone:ecc": "pnpm android:clean-install:ecc",
    "clean-phone:ecc:me": "pnpm android:clean-install:ecc -- -DeviceId R5CY21M3ZRY",
    "clean-phone:pcm": "pnpm android:clean-install:pcm",
    "clean-phone:pcm:me": "pnpm android:clean-install:pcm -- -DeviceId R5CY21M3ZRY",
    "clean-phone:ccfk": "pnpm android:clean-install:ccfk",
    "clean-phone:ccfk:me": "pnpm android:clean-install:ccfk -- -DeviceId R5CY21M3ZRY",
    "bundleRelease:ecc": "pnpm --filter epub-cover-changer bundleRelease",
    "bundleRelease:pcm": "pnpm --filter pdf-cover-maker bundleRelease",
    "bundleRelease:ccfk": "pnpm --filter cover-creator-for-kindle bundleRelease",
    "serve:ecc": "pnpm --filter epub-cover-changer start",
    "serve:ecc:no-open": "pnpm --filter epub-cover-changer exec ionic serve --no-open",
    "serve:pcm": "pnpm --filter pdf-cover-maker start",
    "serve:pcm:no-open": "pnpm --filter pdf-cover-maker exec ionic serve --no-open",
    "serve:ccfk": "pnpm --filter cover-creator-for-kindle start",
    "serve:ccfk:no-open": "pnpm --filter cover-creator-for-kindle exec ionic serve --no-open",
    "increment:version": "node scripts/increment-version-utilidades.cjs",
    "screenshots:ecc": "node tools/playstore/screenshot-ecc.cjs",
    "screenshots:ecc:es": "node tools/playstore/screenshot-ecc.cjs --locales=es-MX",
    "screenshots:pcm": "node tools/playstore/screenshot-pcm.cjs",
    "screenshots:pcm:es": "node tools/playstore/screenshot-pcm.cjs --locales=es-MX",
    "prompts:ecc": "node tools/playstore/generate-ecc-prompts.cjs",
    "prompts:ecc:es": "node tools/playstore/generate-ecc-prompts.cjs --locales=es-MX",
    "prompts:pcm": "node tools/playstore/generate-pcm-prompts.cjs",
    "prompts:pcm:es": "node tools/playstore/generate-pcm-prompts.cjs --locales=es-MX",
    "test": "node --test --test-isolation=none tools/guardrails/**/*.test.mjs tools/settings-kit/**/*.test.mjs tools/native-sqlite-kit/**/*.test.mjs packages/recommended-apps/tests/**/*.test.mjs",
    "lint": "pnpm -r lint",
    "build": "pnpm -r build"
  },
  "devDependencies": {
    "@angular/build": "^20.0.0",
    "@angular/cli": "20.3.16",
    "@angular/compiler-cli": "^20.0.0",
    "@playwright/test": "^1.61.0",
    "jsdom": "^28.0.0",
    "ng-packagr": "^20.3.2",
    "sharp": "0.32.6",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  },
  "dependencies": {
    "@angular/common": "^20.0.0",
    "@angular/compiler": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@angular/forms": "^20.0.0",
    "@angular/platform-browser": "^20.0.0",
    "@angular/router": "^20.0.0",
    "@ionic/angular": "^8.8.8",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "ionicons": "^7.0.0",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.15.1"
  }
}
