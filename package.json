{
  "name": "sheldrapps",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.13.1",
  "scripts": {
    "i": "pnpm install",
    "postinstall": "node scripts/ensure-stencil-entry.cjs && node scripts/patch-capacitor-status-bar.cjs && node scripts/patch-capacitor-admob.cjs && node scripts/patch-capacitor-filesystem.cjs",
    "sync:short-scripts": "node scripts/sync-short-scripts.cjs",
    "dev:cover": "pnpm --filter cover-creator-for-kindle start",
    "build:cover": "pnpm --filter cover-creator-for-kindle build",
    "android:cover": "pnpm --filter cover-creator-for-kindle debugApk",
    "dev:compress": "pnpm --filter compress-pdf start",
    "build:compress": "pnpm --filter compress-pdf build",
    "lint:compress": "pnpm --filter compress-pdf lint",
    "dev:presupuesto": "pnpm --filter presupuesto-ninos start",
    "build:presupuesto": "pnpm --filter presupuesto-ninos build",
    "lint:presupuesto": "pnpm --filter presupuesto-ninos lint",
    "dev:ef": "pnpm --filter epub-fixer start",
    "build:ef": "pnpm --filter epub-fixer build",
    "lint:ef": "pnpm --filter epub-fixer lint",
    "resources:ef": "pnpm --filter epub-fixer assets:android",
    "android:install:ef": "powershell -ExecutionPolicy Bypass -File scripts/install-android-debug.ps1 -AppName epub-fixer",
    "android:clean-install:ef": "powershell -ExecutionPolicy Bypass -File scripts/install-android-debug.ps1 -AppName epub-fixer -UninstallFirst",
    "phone:ef": "pnpm android:install:ef",
    "clean-phone:ef": "pnpm android:clean-install:ef",
    "bundleRelease:ef": "pnpm --filter epub-fixer bundleRelease",
    "serve:ef": "pnpm --filter epub-fixer start",
    "serve:ef:no-open": "pnpm --filter epub-fixer exec ionic serve --no-open",
    "dev:emas": "pnpm --filter epub-merger-and-splitter start",
    "build:emas": "pnpm --filter epub-merger-and-splitter build",
    "lint:emas": "pnpm --filter epub-merger-and-splitter lint",
    "resources:emas": "pnpm --filter epub-merger-and-splitter assets:android",
    "android:install:emas": "powershell -ExecutionPolicy Bypass -File scripts/install-android-debug.ps1 -AppName epub-merger-and-splitter",
    "android:clean-install:emas": "powershell -ExecutionPolicy Bypass -File scripts/install-android-debug.ps1 -AppName epub-merger-and-splitter -UninstallFirst",
    "phone:emas": "pnpm android:install:emas",
    "clean-phone:emas": "pnpm android:clean-install:emas",
    "bundleRelease:emas": "pnpm --filter epub-merger-and-splitter bundleRelease",
    "serve:emas": "pnpm --filter epub-merger-and-splitter start",
    "serve:emas:no-open": "pnpm --filter epub-merger-and-splitter exec ionic serve --no-open",
    "debugApk:emas": "pnpm --filter epub-merger-and-splitter debugApk",
    "releaseApk:emas": "pnpm --filter epub-merger-and-splitter releaseApk",
    "android:install": "powershell -ExecutionPolicy Bypass -File scripts/install-android-debug.ps1",
    "android:install:ecc": "powershell -ExecutionPolicy Bypass -File scripts/install-android-debug.ps1 -AppName epub-cover-changer",
    "android:install:pcm": "powershell -ExecutionPolicy Bypass -File scripts/install-android-debug.ps1 -AppName pdf-cover-maker",
    "android:install:ccfk": "powershell -ExecutionPolicy Bypass -File scripts/install-android-debug.ps1 -AppName cover-creator-for-kindle",
    "android:clean-install:ecc": "powershell -ExecutionPolicy Bypass -File scripts/install-android-debug.ps1 -AppName epub-cover-changer -UninstallFirst",
    "android:clean-install:pcm": "powershell -ExecutionPolicy Bypass -File scripts/install-android-debug.ps1 -AppName pdf-cover-maker -UninstallFirst",
    "android:clean-install:ccfk": "powershell -ExecutionPolicy Bypass -File scripts/install-android-debug.ps1 -AppName cover-creator-for-kindle -UninstallFirst",
    "phone:ecc": "pnpm android:install:ecc",
    "phone:pcm": "pnpm android:install:pcm",
    "phone:ccfk": "pnpm android:install:ccfk",
    "clean-phone:ecc": "pnpm android:clean-install:ecc",
    "clean-phone:pcm": "pnpm android:clean-install:pcm",
    "clean-phone:ccfk": "pnpm android:clean-install:ccfk",
    "debugApk:ef": "pnpm --filter epub-fixer debugApk",
    "releaseApk:ef": "pnpm --filter epub-fixer releaseApk",
    "bundleRelease:ecc": "pnpm --filter epub-cover-changer bundleRelease",
    "bundleRelease:pcm": "pnpm --filter pdf-cover-maker bundleRelease",
    "bundleRelease:ccfk": "pnpm --filter cover-creator-for-kindle bundleRelease",
    "serve:ecc": "pnpm --filter epub-cover-changer start",
    "serve:ecc:no-open": "pnpm --filter epub-cover-changer exec ionic serve --no-open",
    "serve:pcm": "pnpm --filter pdf-cover-maker start",
    "serve:pcm:no-open": "pnpm --filter pdf-cover-maker exec ionic serve --no-open",
    "serve:ccfk": "pnpm --filter cover-creator-for-kindle start",
    "serve:ccfk:no-open": "pnpm --filter cover-creator-for-kindle exec ionic serve --no-open",
    "increment:version": "node scripts/increment-version-utilidades.cjs",
    "repair:app-i18n": "node scripts/repair-app-i18n.cjs",
    "repair:emas-i18n": "node scripts/repair-emas-i18n.cjs",
    "screenshots:ecc": "node tools/playstore/screenshot-ecc.cjs",
    "screenshots:ecc:es": "node tools/playstore/screenshot-ecc.cjs --locales=es-MX",
    "screenshots:pcm": "node tools/playstore/screenshot-pcm.cjs",
    "screenshots:pcm:es": "node tools/playstore/screenshot-pcm.cjs --locales=es-MX",
    "prompts:ecc": "node tools/playstore/generate-ecc-prompts.cjs",
    "prompts:ecc:es": "node tools/playstore/generate-ecc-prompts.cjs --locales=es-MX",
    "prompts:pcm": "node tools/playstore/generate-pcm-prompts.cjs",
    "prompts:pcm:es": "node tools/playstore/generate-pcm-prompts.cjs --locales=es-MX",
    "test": "node --test --test-isolation=none tools/guardrails/**/*.test.mjs tools/settings-kit/**/*.test.mjs tools/native-sqlite-kit/**/*.test.mjs packages/recommended-apps/tests/**/*.test.mjs",
    "lint": "pnpm -r lint",
    "build": "pnpm -r build",
    "dev:ecc": "pnpm --filter epub-cover-changer start",
    "build:ecc": "pnpm --filter epub-cover-changer build",
    "lint:ecc": "pnpm --filter epub-cover-changer lint",
    "resources:ecc": "pnpm --filter epub-cover-changer assets:android",
    "debugApk:ecc": "pnpm --filter epub-cover-changer debugApk",
    "releaseApk:ecc": "pnpm --filter epub-cover-changer releaseApk",
    "dev:pcm": "pnpm --filter pdf-cover-maker start",
    "build:pcm": "pnpm --filter pdf-cover-maker build",
    "lint:pcm": "pnpm --filter pdf-cover-maker lint",
    "resources:pcm": "pnpm --filter pdf-cover-maker assets:android",
    "debugApk:pcm": "pnpm --filter pdf-cover-maker debugApk",
    "releaseApk:pcm": "pnpm --filter pdf-cover-maker releaseApk",
    "dev:ccfk": "pnpm --filter cover-creator-for-kindle start",
    "build:ccfk": "pnpm --filter cover-creator-for-kindle build",
    "lint:ccfk": "pnpm --filter cover-creator-for-kindle lint",
    "resources:ccfk": "pnpm --filter cover-creator-for-kindle assets:android",
    "debugApk:ccfk": "pnpm --filter cover-creator-for-kindle debugApk",
    "releaseApk:ccfk": "pnpm --filter cover-creator-for-kindle releaseApk",
    "dev:active": "pnpm dev:ecc && pnpm dev:ccfk && pnpm dev:pcm && pnpm dev:ef && pnpm dev:emas",
    "build:active": "pnpm build:ecc && pnpm build:ccfk && pnpm build:pcm && pnpm build:ef && pnpm build:emas",
    "lint:active": "pnpm lint:ecc && pnpm lint:ccfk && pnpm lint:pcm && pnpm lint:ef && pnpm lint:emas",
    "resources:active": "pnpm resources:ecc && pnpm resources:ccfk && pnpm resources:pcm && pnpm resources:ef && pnpm resources:emas",
    "android:install:active": "pnpm android:install:ecc && pnpm android:install:ccfk && pnpm android:install:pcm && pnpm android:install:ef && pnpm android:install:emas",
    "android:clean-install:active": "pnpm android:clean-install:ecc && pnpm android:clean-install:ccfk && pnpm android:clean-install:pcm && pnpm android:clean-install:ef && pnpm android:clean-install:emas",
    "phone:active": "pnpm android:install:active",
    "clean-phone:active": "pnpm android:clean-install:active",
    "bundleRelease:active": "pnpm bundleRelease:ecc && pnpm bundleRelease:ccfk && pnpm bundleRelease:pcm && pnpm bundleRelease:ef && pnpm bundleRelease:emas",
    "serve:active": "pnpm serve:ecc && pnpm serve:ccfk && pnpm serve:pcm && pnpm serve:ef && pnpm serve:emas",
    "serve:active:no-open": "pnpm serve:ecc:no-open && pnpm serve:ccfk:no-open && pnpm serve:pcm:no-open && pnpm serve:ef:no-open && pnpm serve:emas:no-open",
    "debugApk:active": "pnpm debugApk:ecc && pnpm debugApk:ccfk && pnpm debugApk:pcm && pnpm debugApk:ef && pnpm debugApk:emas",
    "releaseApk:active": "pnpm releaseApk:ecc && pnpm releaseApk:ccfk && pnpm releaseApk:pcm && pnpm releaseApk:ef && pnpm releaseApk:emas",
    "dev:editor": "pnpm dev:ecc && pnpm dev:ccfk && pnpm dev:pcm && pnpm dev:emas",
    "build:editor": "pnpm build:ecc && pnpm build:ccfk && pnpm build:pcm && pnpm build:emas",
    "lint:editor": "pnpm lint:ecc && pnpm lint:ccfk && pnpm lint:pcm && pnpm lint:emas",
    "resources:editor": "pnpm resources:ecc && pnpm resources:ccfk && pnpm resources:pcm && pnpm resources:emas",
    "android:install:editor": "pnpm android:install:ecc && pnpm android:install:ccfk && pnpm android:install:pcm && pnpm android:install:emas",
    "android:clean-install:editor": "pnpm android:clean-install:ecc && pnpm android:clean-install:ccfk && pnpm android:clean-install:pcm && pnpm android:clean-install:emas",
    "phone:editor": "pnpm android:install:editor",
    "clean-phone:editor": "pnpm android:clean-install:editor",
    "bundleRelease:editor": "pnpm bundleRelease:ecc && pnpm bundleRelease:ccfk && pnpm bundleRelease:pcm && pnpm bundleRelease:emas",
    "serve:editor": "pnpm serve:ecc && pnpm serve:ccfk && pnpm serve:pcm && pnpm serve:emas",
    "serve:editor:no-open": "pnpm serve:ecc:no-open && pnpm serve:ccfk:no-open && pnpm serve:pcm:no-open && pnpm serve:emas:no-open",
    "debugApk:editor": "pnpm debugApk:ecc && pnpm debugApk:ccfk && pnpm debugApk:pcm && pnpm debugApk:emas",
    "releaseApk:editor": "pnpm releaseApk:ecc && pnpm releaseApk:ccfk && pnpm releaseApk:pcm && pnpm releaseApk:emas"
  },
  "devDependencies": {
    "@angular/build": "^22.0.7",
    "@angular/cli": "22.0.7",
    "@angular/compiler-cli": "^22.0.7",
    "@playwright/test": "^1.61.0",
    "jsdom": "^28.0.0",
    "ng-packagr": "^20.3.2",
    "sharp": "0.35.3",
    "typescript": "~6.0.3",
    "vitest": "^4.0.8"
  },
  "dependencies": {
    "@angular/common": "^22.0.7",
    "@angular/compiler": "^22.0.7",
    "@angular/core": "^22.0.7",
    "@angular/forms": "^22.0.7",
    "@angular/platform-browser": "^22.0.7",
    "@angular/router": "^22.0.7",
    "@ionic/angular": "^8.8.14",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "ionicons": "^7.0.0",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.15.1"
  },
  "engines": {
    "node": "^22.22.3 || ^24.15.0 || ^26.0.0"
  }
}
